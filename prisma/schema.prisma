generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../contracts/src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique
  password    String
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  phone       String?
  warehouseId Int?      @map("warehouse_id")
  isActive    Boolean   @default(true) @map("is_active")
  lastSeen    DateTime? @map("last_seen")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  warehouse       Warehouse?               @relation(fields: [warehouseId], references: [id])
  roleAssignments EmployeeRoleAssignment[]

  @@map("employee")
}

model EmployeeRole {
  id        Int   @id @default(autoincrement())
  name      String   @unique
  color     String
  updatedAt DateTime @updatedAt @map("updated_at")

  assignments EmployeeRoleAssignment[]
  permissions EmployeeRolePermission[]

  @@map("employee_role")
}

model EmployeePermission {
  id        Int   @id @default(autoincrement())
  name      String   @unique
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions EmployeeRolePermission[]

  @@map("employee_permission")
}

model ServerSettings {
  id             Int      @id @default(1)
  setupCompleted Boolean  @default(false) @map("setup_completed")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("server_settings")
}

model EmployeeRoleAssignment {
  id             Int   @id @default(autoincrement())
  employeeId     String   @map("employee_id") @db.Uuid
  employeeRoleId Int   @map("employee_role_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeRole EmployeeRole @relation(fields: [employeeRoleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, employeeRoleId])
  @@map("employee_role_assignment")
}

model EmployeeRolePermission {
  id                   Int   @id @default(autoincrement())
  employeeRoleId       Int   @map("employee_role_id")
  employeePermissionId Int   @map("employee_permission_id")
  updatedAt            DateTime @updatedAt @map("updated_at")

  employeeRole       EmployeeRole       @relation(fields: [employeeRoleId], references: [id], onDelete: Cascade)
  employeePermission EmployeePermission @relation(fields: [employeePermissionId], references: [id], onDelete: Cascade)

  @@unique([employeeRoleId, employeePermissionId])
  @@map("employee_role_permission")
}

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.Char(2)
  currency  String?  @db.Char(3)
  updatedAt DateTime @updatedAt @map("updated_at")

  localities Locality[]

  @@map("country")
}

model Locality {
  id        Int      @id @default(autoincrement())
  name      String
  countryId Int      @map("country_id")
  updatedAt DateTime @updatedAt @map("updated_at")

  country    Country     @relation(fields: [countryId], references: [id])
  warehouses Warehouse[]

  @@map("locality")
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  website   String?
  updatedAt DateTime @updatedAt @map("updated_at")

  warehouses Warehouse[]

  @@map("organization")
}

model Warehouse {
  id             Int      @id @default(autoincrement())
  address        String
  note           String?
  code           String   @unique
  organizationId Int      @map("organization_id")
  localityId     Int      @map("locality_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  locality     Locality     @relation(fields: [localityId], references: [id])
  employees    Employee[]

  @@map("warehouse")
}
