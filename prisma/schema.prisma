generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../contracts/src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WriteoffStrategy {
  FIFO
  LIFO
  FEFO
  MANUAL
}

enum SkuMode {
  GLOBAL
  CUSTOM
}

enum BarcodeType {
  FACTORY
  CUSTOM

  @@map("barcode_type")
}

model ProductMeasure {
  id        Int      @id @default(autoincrement())
  name      String?  @unique
  code      String?  @unique
  updatedAt DateTime @updatedAt @map("updated_at")

  products ProductItem[]

  @@map("product_measure")
}

model ProductBrand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  updatedAt DateTime @updatedAt @map("updated_at")

  products ProductItem[]

  @@map("product_brand")
}

model ProductType {
  id                      Int              @id @default(autoincrement())
  name                    String
  defaultWriteoffStrategy WriteoffStrategy @default(FIFO) @map("default_writeoff_strategy")
  skuMode                 SkuMode          @default(GLOBAL) @map("sku_mode")
  skuTemplate             String?          @map("sku_template")
  skuCounter              Int              @default(0) @map("sku_counter")
  characteristicsScheme   Json?            @map("characteristics_scheme")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  collections ProductCollection[]
  items       ProductItem[]

  @@map("product_type")
}

model Folder {
  id        Int       @id @default(autoincrement())
  name      String
  parentId  Int?      @map("parent_id")
  pinnedAt  DateTime? @map("pinned_at")
  pinOrder  Int?      @map("pin_order")
  updatedAt DateTime  @updatedAt @map("updated_at")

  parent      Folder?             @relation("FolderTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    Folder[]            @relation("FolderTree")
  collections ProductCollection[]

  @@map("folder")
}

model ProductCollection {
  id                   Int       @id @default(autoincrement())
  name                 String
  folderId             Int?      @map("folder_id")
  defaultProductTypeId Int?      @map("default_product_type_id")
  pinnedAt             DateTime? @map("pinned_at")
  pinOrder             Int?      @map("pin_order")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  folder             Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  defaultProductType ProductType? @relation(fields: [defaultProductTypeId], references: [id], onDelete: SetNull)
  items              ProductItem[]

  @@unique([folderId, name])
  @@map("product_collection")
}

model ProductItem {
  id                  Int               @id @default(autoincrement())
  sku                 String            @unique
  name                String
  productCollectionId Int?              @map("product_collection_id")
  productTypeId       Int               @map("product_type_id")
  productBrandId      Int?              @map("product_brand_id")
  productMeasureId    Int?              @map("product_measure_id")
  countryId           Int?              @map("country_id")
  characteristics     Json              @default("{}") @map("characteristics")
  writeoffStrategy    WriteoffStrategy? @map("writeoff_strategy")
  isPublic            Boolean           @default(false) @map("is_public")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  productCollection ProductCollection? @relation(fields: [productCollectionId], references: [id], onDelete: SetNull)
  productType       ProductType        @relation(fields: [productTypeId], references: [id])
  productBrand      ProductBrand?      @relation(fields: [productBrandId], references: [id], onDelete: SetNull)
  productMeasure    ProductMeasure?    @relation(fields: [productMeasureId], references: [id], onDelete: SetNull)
  country           Country?           @relation(fields: [countryId], references: [id], onDelete: SetNull)
  barcodes          ProductBarcode[]
  packages          ProductPackage[]
  shipments         ProductShipment[]

  @@map("product_item")
}

model ProductBarcode {
  id            Int         @id @default(autoincrement())
  code          String
  type          BarcodeType @default(FACTORY)
  productItemId Int         @map("product_item_id")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  productItem ProductItem @relation(fields: [productItemId], references: [id], onDelete: Cascade)

  @@unique([code, type])
  @@map("product_barcode")
}

model ProductPackage {
  id               Int      @id @default(autoincrement())
  name             String
  productItemId    Int      @map("product_item_id")
  conversionFactor Float    @default(1) @map("conversion_factor")
  retailPrice      Decimal  @default(0) @map("retail_price") @db.Decimal(10, 2)
  updatedAt        DateTime @updatedAt @map("updated_at")

  productItem ProductItem @relation(fields: [productItemId], references: [id], onDelete: Cascade)

  @@map("product_package")
}

model ProductShipment {
  id            Int       @id @default(autoincrement())
  warehouseId   Int       @map("warehouse_id")
  productItemId Int       @map("product_item_id")
  arrivalDate   DateTime  @map("arrival_date")
  expiryDate    DateTime? @map("expiry_date") @db.Date
  quantity      Decimal   @default(0) @db.Decimal(8, 2)
  price         Decimal   @default(0) @db.Decimal(10, 2)
  updatedAt     DateTime  @updatedAt @map("updated_at")

  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  productItem ProductItem @relation(fields: [productItemId], references: [id])

  @@map("product_shipment")
}

model Employee {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique
  password    String
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  phone       String?
  avatarUrl   String?   @map("avatar_url")
  warehouseId Int?      @map("warehouse_id")
  isActive    Boolean   @default(true) @map("is_active")
  lastSeen    DateTime? @map("last_seen")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  warehouse       Warehouse?               @relation(fields: [warehouseId], references: [id])
  roleAssignments EmployeeRoleAssignment[]

  @@map("employee")
}

model EmployeeRole {
  id        Int   @id @default(autoincrement())
  name      String   @unique
  color     String
  updatedAt DateTime @updatedAt @map("updated_at")

  assignments EmployeeRoleAssignment[]
  permissions EmployeeRolePermission[]

  @@map("employee_role")
}

model EmployeePermission {
  id        Int   @id @default(autoincrement())
  name      String   @unique
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions EmployeeRolePermission[]

  @@map("employee_permission")
}

model ServerSettings {
  id             Int      @id @default(1)
  setupCompleted Boolean  @default(false) @map("setup_completed")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("server_settings")
}

model EmployeeRoleAssignment {
  id             Int   @id @default(autoincrement())
  employeeId     String   @map("employee_id") @db.Uuid
  employeeRoleId Int   @map("employee_role_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeRole EmployeeRole @relation(fields: [employeeRoleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, employeeRoleId])
  @@map("employee_role_assignment")
}

model EmployeeRolePermission {
  id                   Int   @id @default(autoincrement())
  employeeRoleId       Int   @map("employee_role_id")
  employeePermissionId Int   @map("employee_permission_id")
  updatedAt            DateTime @updatedAt @map("updated_at")

  employeeRole       EmployeeRole       @relation(fields: [employeeRoleId], references: [id], onDelete: Cascade)
  employeePermission EmployeePermission @relation(fields: [employeePermissionId], references: [id], onDelete: Cascade)

  @@unique([employeeRoleId, employeePermissionId])
  @@map("employee_role_permission")
}

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.Char(2)
  currency  String?  @db.Char(3)
  updatedAt DateTime @updatedAt @map("updated_at")

  localities Locality[]
  products   ProductItem[]

  @@map("country")
}

model Locality {
  id        Int      @id @default(autoincrement())
  name      String
  countryId Int      @map("country_id")
  updatedAt DateTime @updatedAt @map("updated_at")

  country    Country     @relation(fields: [countryId], references: [id])
  warehouses Warehouse[]

  @@map("locality")
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  website   String?
  updatedAt DateTime @updatedAt @map("updated_at")

  warehouses Warehouse[]

  @@map("organization")
}

model Warehouse {
  id             Int      @id @default(autoincrement())
  address        String
  note           String?
  code           String   @unique
  organizationId Int      @map("organization_id")
  localityId     Int      @map("locality_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id])
  locality     Locality          @relation(fields: [localityId], references: [id])
  employees    Employee[]
  shipments    ProductShipment[]

  @@map("warehouse")
}
