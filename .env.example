### APP ###
APP_PORT=3000

### DATABASE ###
# For meerk-postgres and meerk-wms Docker containers
POSTGRES_USER=meerk
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=meerk-postgres
POSTGRES_PORT=5432
POSTGRES_DB=meerk_db

### REDIS ###
REDIS_HOST=meerk-redis
REDIS_PORT=6379

### S3 / MINIO ###
S3_ENDPOINT=http://meerk-minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
S3_BUCKET=meerk

### JWT ###
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

### CORS ###
# Used by CORS, you can leave it as * or place your domain there
FRONT_END_DOMAIN=*
COOKIE_SECURE=true

### DOCS ###
IS_DOCS_ENABLED=false
SCALAR_PATH=/docs

### DATABASE [DEV] ###
# For Prisma
# Format: postgresql://{user}:{password}@{host}:{port}/{database}
# DATABASE_URL=postgresql://meerk:change_me@meerk-postgres:5432/meerk_db
